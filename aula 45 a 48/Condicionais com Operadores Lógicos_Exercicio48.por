programa {
  funcao inicio() {

    cadeia tamanhoCamisa

    escreva("Informe o tamanho da camisa: ")
    leia(tamanhoCamisa)

    se(tamanhoCamisa == "P"){
      escreva("Tamanho Pequeno.")
    }
    se(tamanhoCamisa == "M"){
      escreva("Tamanho Médio.")
    }
    se(tamanhoCamisa == "G"){
      escreva("Tamanho Grande.")
    }
    se(tamanhoCamisa == "GG"){
      escreva("Tamanho Grande-Grande.")
    }
    se(tamanhoCamisa == "XG"){
      escreva("Tamanho Extra-Grande.")
    }
    
  }
}
