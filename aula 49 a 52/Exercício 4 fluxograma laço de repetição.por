programa {
  funcao inicio() {
   cadeia nome
    inteiro quantidade, quantidadeDesejada

    escreva ("Digite seu nome: " )
    leia (nome)
    escreva ("Digite a quantidade desejada: " )
    leia (quantidadeDesejada)

    para ( quantidade = 1; quantidade <= quantidadeDesejada; quantidade ++ ){
      escreva (nome, "\n")
    }

  }
}
